							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"campaignId\": \"{{campaignId}}\",\n    \"amount\": 100,\n    \"idempotencyKey\": \"pledge-{{$timestamp}}-{{$randomInt}}\",\n    \"userId\": \"{{userId}}\",\n    \"message\": \"Keep up the great work!\",\n    \"anonymous\": false\n}"
						},
						"url": {
							"raw": "http://localhost:8000/api/pledges",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8000",
							"path": ["api", "pledges"]
						}
					}
				},
				{
					"name": "Create Pledge (Duplicate - Test Idempotency)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"campaignId\": \"{{campaignId}}\",\n    \"amount\": 100,\n    \"idempotencyKey\": \"pledge-test-same-key\",\n    \"userId\": \"{{userId}}\",\n    \"message\": \"Duplicate request\",\n    \"anonymous\": false\n}"
						},
						"url": {
							"raw": "http://localhost:8000/api/pledges",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8000",
							"path": ["api", "pledges"]
						},
						"description": "Send this request twice with the same idempotencyKey to test idempotency"
					}
				},
				{
					"name": "Get Pledge by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
